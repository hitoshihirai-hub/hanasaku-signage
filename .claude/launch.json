{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "static (display + mobile)",
      "runtimeExecutable": "py",
      "runtimeArgs": ["-m", "http.server", "8080"],
      "port": 8080
    },
    {
      "name": "api (FastAPI)",
      "runtimeExecutable": "py",
      "runtimeArgs": [
        "-m",
        "uvicorn",
        "app:app",
        "--reload",
        "--app-dir",
        "server",
        "--port",
        "8000"
      ],
      "port": 8000
    }
  ]
}
